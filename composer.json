{
    "name": "yl0711-coder/ruleflow-php",
    "description": "A lightweight, explainable rule engine for PHP and Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "rule-engine",
        "laravel",
        "risk-control",
        "content-moderation",
        "business-rules"
    ],
    "authors": [
        {
            "name": "Yang Lei",
            "email": "yanglei711@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.5|^12.0",
        "squizlabs/php_codesniffer": "^3.9",
        "phpstan/phpstan": "^1.12"
    },
    "suggest": {
        "laravel/framework": "Required when using RuleFlow as a Laravel package."
    },
    "autoload": {
        "psr-4": {
            "RuleFlow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RuleFlow\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RuleFlow\\Laravel\\RuleFlowServiceProvider"
            ],
            "aliases": {
                "RuleFlow": "RuleFlow\\Laravel\\Facades\\RuleFlow"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-clover build/logs/clover.xml",
        "lint": "vendor/bin/phpcs --standard=PSR12 src tests examples",
        "analyse": "vendor/bin/phpstan analyse --configuration=phpstan.neon.dist --debug --no-progress",
        "examples": [
            "php examples/order-risk.php",
            "php examples/content-moderation.php",
            "php examples/json-loader.php",
            "php examples/explain.php"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
